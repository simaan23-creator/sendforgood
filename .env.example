# SealTheDay environment variables.
# Copy to .env.local for local dev. Set the same values in Vercel for prod.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://sealtheday.com
NEXT_PUBLIC_SITE_URL=https://sealtheday.com

# ─── Admin auth ──────────────────────────────────────────────────────────────
# Strong random string. Used by /admin gate and all /api/admin/** routes.
ADMIN_PASSWORD=

# ─── Cron auth ───────────────────────────────────────────────────────────────
# Required by Vercel cron headers: Authorization: Bearer <CRON_SECRET>
# Generate with: openssl rand -hex 32
CRON_SECRET=
